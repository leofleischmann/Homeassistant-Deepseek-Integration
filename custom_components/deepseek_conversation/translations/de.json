        "run_debug": {
            "name": "DeepSeek-Debug ausführen",
            "description": "Umfassende Diagnose: Umgebung, HTTP-Probe, optional models.list, registrierte HA-LLM-APIs, Entity-Registry, viele chat.completions- und Stream-Tests (Thinking an/aus, Systemnachricht, Mehr-Turn, JSON-Modus, parallele Mini-Pings), Log-Auszug und JSON-Anhang im Report. Viele kurze API-Aufrufe; schreibt /config/deepseek_conversation_debug_report.txt und eine Kurznotiz (Zusammenfassung + Fehler).",
            "fields": {
                "config_entry": {
                    "name": "Integrations-Eintrag",
                    "description": "Welcher DeepSeek-Conversation-Eintrag getestet werden soll."
                },
                "log_tail_lines": {
                    "name": "Log-Auszug (Zeilen)",
